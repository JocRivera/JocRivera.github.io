---
const particles = Array.from({ length: 25 }).map(() => ({
  left: Math.random() * 100,
  delay: Math.random() * 10,
  duration: 8 + Math.random() * 12,
  size: 2 + Math.random() * 3,
}));
---

<div class="retro-bg">
  <!-- Horizon Glow -->
  <div class="sun"></div>

  <!-- Grid -->
  <div class="grid"></div>

  <!-- Particles -->
  {particles.map((p) => (
    <div
      class="particle"
      style={`
        left:${p.left}%;
        animation-delay:${p.delay}s;
        animation-duration:${p.duration}s;
        width:${p.size}px;
        height:${p.size}px;
      `}
    ></div>
  ))}

  <!-- Overlay -->
  <div class="overlay"></div>
</div>

<style>
.retro-bg {
  position: fixed;
  inset: 0;
  z-index: -10;
  overflow: hidden;
  background: #0a0e27;
  pointer-events: none;
}

/* 🌅 Retro Sun Glow */
.sun {
  position: absolute;
  bottom: -200px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, #ff6b35 0%, #ff2e63 40%, transparent 70%);
  opacity: 0.25;
  filter: blur(80px);
}

/* 🟧 Grid */
.grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 107, 53, 0.25) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 107, 53, 0.25) 1px, transparent 1px);
  background-size: 60px 60px;
  transform: perspective(500px) rotateX(60deg);
  transform-origin: bottom;
  animation: gridMove 12s linear infinite;
  opacity: 0.4;
}

/* ✨ Particles */
.particle {
  position: absolute;
  bottom: -10px;
  background: #4ecdc4;
  border-radius: 50%;
  box-shadow: 0 0 8px rgba(78, 205, 196, 0.9);
  animation: floatUp infinite ease-in;
}

@keyframes floatUp {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(-110vh);
    opacity: 0;
  }
}

@keyframes gridMove {
  from {
    background-position-y: 0px;
  }
  to {
    background-position-y: 60px;
  }
}

/* 🌌 Overlay */
.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, #0a0e27 0%, transparent 40%, #0a0e27 100%);
}
</style>