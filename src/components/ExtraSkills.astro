---
import { Languages, Music } from "@lucide/astro";

interface ExtraSkill {
  title: string;
  subtitle: string;
  color: string;
  icon: 'languages' | 'music';
}

const iconMap = {
  languages: Languages,
  music: Music,
};

const { extraSkills } = Astro.props as { extraSkills: ExtraSkill[] };
---

<div class="extra-skills">
  {extraSkills.map((skill, index) => {
    const Icon = iconMap[skill.icon];

    return (
      <div
        class="skill-card"
        style={`border-color:${skill.color}; animation-delay:${0.5 + index * 0.1}s`}
      >
        <div
          class="icon"
          style={`background:${skill.color}; box-shadow:0 0 20px ${skill.color}80`}
        >
          <Icon size={28} stroke-width={2} color="#0a0e27" />
        </div>

        <div>
          <h3 class="title" style={`color:${skill.color}`}>
            {skill.title}
          </h3>
          <p class="subtitle">{skill.subtitle}</p>
        </div>
      </div>
    );
  })}
</div>

<style>
.extra-skills {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.skill-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem;

  background: linear-gradient(to bottom right, #1a1f3a, #0a0e27);
  border: 2px solid;
  border-radius: 4px;

  box-shadow: 0 0 20px rgba(78, 205, 196, 0.2);
  transition: all 0.3s ease;

  opacity: 0;
  transform: translateX(20px);
  animation: slideIn 0.4s forwards ease;
}

.skill-card:hover {
  transform: translateX(5px) scale(1.03);
  box-shadow: 0 0 30px rgba(78, 205, 196, 0.5);
}

.icon {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  flex-shrink: 0;
}

.title {
  font-size: 1.25rem;
  font-weight: bold;
}

.subtitle {
  color: #a8b2d1;
  font-size: 0.85rem;
}

@keyframes slideIn {
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
</style>