---
import astroLogo from "../assets/astro.svg";
import background from "../assets/background.svg";
import Header from "./Header.astro";
import SkillsSection from "./SkillsSection.astro";
import ProjectCard from "./ProjectCard.astro";
import HorizontalTimeline from "./HorizontalTimeline.astro";
import {
	Code2,
	Palette,
	Rocket,
	Users,
	Lightbulb,
	Heart,
	Languages,
	Music,
} from "@lucide/astro";
import ExtraSkills from "./ExtraSkills.astro";

const skills = [
	{ name: "Java", level: 5, icon: "code" },
	{ name: "Git", level: 5, icon: "github" },
	{ name: "MongoDB & SQL", level: 5, icon: "database" },
	{ name: "Junit", level: 4, icon: "server" },
	{ name: "Springboot", level: 4, icon: "database" },
	{ name: "Angular", level: 4, icon: "palette" },
	{ name: "React", level: 4, icon: "palette" },
	{ name: "Node.js", level: 4, icon: "terminal" },
];
const projects = [
	{
		title: "Proyecto de grado",
		description:
			"Proyecto basado en sistema de gestión hotelera y turística.",
		tags: ["React", "Node.js", "SQL", "Deploy"],
		link: "https://github.com/JocRivera/BookEdge",
	},
	{
		title: "Carrito de compras",
		description:
			"proyecto e-commerce genérico y gestión de compra y/o venta online. ",
		tags: ["React", "Node.js", "MongoDB", "Shadcn/ui"],
		link: "https://github.com/JocRivera/backend",
	},
	{
		title: "Proyecto personal",
		description:
			"proyecto donde se estudia la técnica scrapping para mostrar información meteorológica en un territorio. ",
		tags: ["React", "Node.js", "Leaflet", "Scraping"],
		link: "https://github.com/JocRivera/caminando-territorio",
	},
];
const timelineData = [
	{
		year: "2020 - 2023",
		title: "Servicio al cliente, mesa y bar",
		company: "HOSTERíA LOS LAGOS SPA",
		description: "Aunque no relacionado con el área de las TICS, esta experiencia ha fortalecido habilidades blandas. ",
	},
	{
		year: "2023 - 2025",
		title: "Tecnólogo en Analisis y Desarrollo de Software",
		company: "Servicio Nacional de Aprendizaje SENA",
		description: "Desarrollo de sistema de gestión hotelera como proyecto de grado.",
	},
{
	year: "2025 - 2026",
	title: "Desarrollador Full Stack",
	company: "QUIPUX S.A.S",
	description: "Se implementan buenas prácticas de desarrollo con sus respectivas pruebas unitarias, manejo de consultas y bases de datos relacionales, en una empresa que ofrece plataformas y soluciones digitales a la movilidad ciudadana, basándose en una arquitectura por componentes.",
},
];
const aboutMe = [
	{
		Icon: Code2,
		text: "Desarrollo de aplicaciones web modernas y escalables",
		color: "#4ecdc4",
	},
	{
		Icon: Palette,
		text: "Diseño de interfaces creativas y centradas en el usuario",
		color: "#ff6b35",
	},
	{
		Icon: Rocket,
		text: "Optimización de rendimiento y mejores prácticas",
		color: "#fdc830",
	},
	{
		Icon: Users,
		text: "Colaboración efectiva en equipos multidisciplinarios",
		color: "#4ecdc4",
	},
	{
		Icon: Lightbulb,
		text: "Innovación constante con nuevas tecnologías",
		color: "#f7931e",
	},
	{
		Icon: Heart,
		text: "Pasión por crear experiencias digitales memorables",
		color: "#ff6b35",
	},
	{
		Icon: Languages,
		text: "Habilidades multilingües para proyectos internacionales",
		color: "#4ecdc4",
	},
	{
		Icon: Music,
		text: "Intereses en música y su impacto en la creatividad",
		color: "#ff6b35",
	},
];
const extraSkills = [
	{
		title: "Inglés",
		subtitle: "Estudiante",
		color: "#4ecdc4",
		icon: "languages",
	},
	{
		title: "Intérprete Musical",
		subtitle: "Instrumentista",
		color: "#ff6b35",
		icon: "music",
	},
];

---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<header>
		<Header />
	</header>
	<main class="main-container">
		<div class="two-columns">
			<!-- Left Column -->
			<section class="fade-left">
				<div class="section-header">
					<h2 class="title teal">Lenguajes & Herramientas</h2>
					<div class="underline teal"></div>
				</div>

				<SkillsSection skills={skills} />
			</section>

			<!-- Right Column -->
			<section class="fade-right">
				<div class="section-header">
					<h2 class="title orange">Proyectos Destacados</h2>
					<div class="underline orange"></div>
				</div>

				<div class="projects">
					{
						projects.map((project, index) => (
							<ProjectCard {...project} index={index} />
						))
					}
				</div>

				<div class="section-header">
					<h2 class="title orange">Habilidades Adicionales</h2>
					<div class="underline orange"></div>
				</div>
				<ExtraSkills extraSkills={extraSkills} />
			</section>
		</div>
		<section class="experience-section">
			<div class="section-header">
				<div class="section-header">
					<h2 class="title orange">Experiencia</h2>
					<div class="underline orange"></div>
				</div>
				<div class="underline"></div>
			</div>

			<HorizontalTimeline items={timelineData} />
		</section>
		<section class="about-section">
			<div class="section-header">
					<h2 class="title orange">Sobre mí</h2>
					<div class="underline orange"></div>
				</div>

			<div class="about-grid">
				{
					aboutMe.map((item) => (
						<div
							class="about-card"
							style={`border-color:${item.color}`}
						>
							<div
								class="icon-wrapper"
								style={`background:${item.color}; box-shadow:0 0 20px ${item.color}80`}
							>
								<item.Icon size={24} color="#0a0e27" />
							</div>

							<p>{item.text}</p>
						</div>
					))
				}
			</div>
		</section>
	</main>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family:
			Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial,
			sans-serif;
	}

	main {
		width: 100%;
	}

	.main-container {
		max-width: 1280px;
		margin-left: auto;
		margin-right: auto;
		padding-left: 1.5rem;
		padding-right: 1.5rem;
		padding-top: 3rem;
		padding-bottom: 3rem;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		padding: 16px;
	}

	h1 {
		font-size: 22px;
		margin-top: 0.25em;
	}

	#links {
		display: flex;
		gap: 16px;
	}

	#links a {
		display: flex;
		align-items: center;
		padding: 10px 12px;
		color: #111827;
		text-decoration: none;
		transition: color 0.2s;
	}

	#links a:hover {
		color: rgb(78, 80, 86);
	}

	#links a svg {
		height: 1em;
		margin-left: 8px;
	}

	#links a.button {
		color: white;
		background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.12),
			inset 0 -2px 0 rgba(0, 0, 0, 0.24);
		border-radius: 10px;
	}

	#links a.button:hover {
		color: rgb(230, 230, 230);
		box-shadow: none;
	}

	pre {
		font-family:
			ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas,
			"DejaVu Sans Mono", monospace;
		font-weight: normal;
		background: linear-gradient(14deg, #d83333 0%, #f041ff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0;
	}

	h2 {
		margin: 0 0 1em;
		font-weight: normal;
		color: #111827;
		font-size: 20px;
	}

	p {
		color: #4b5563;
		font-size: 16px;
		line-height: 24px;
		letter-spacing: -0.006em;
		margin: 0;
	}

	code {
		display: inline-block;
		background:
			linear-gradient(66.77deg, #f3cddd 0%, #f5cee7 100%) padding-box,
			linear-gradient(155deg, #d83333 0%, #f041ff 18%, #f5cee7 45%)
				border-box;
		border-radius: 8px;
		border: 1px solid transparent;
		padding: 6px 8px;
	}

	.box {
		padding: 16px;
		background: rgba(255, 255, 255, 1);
		border-radius: 16px;
		border: 1px solid white;
	}

	#news {
		position: absolute;
		bottom: 16px;
		right: 16px;
		max-width: 300px;
		text-decoration: none;
		transition: background 0.2s;
		backdrop-filter: blur(50px);
	}

	#news:hover {
		background: rgba(255, 255, 255, 0.55);
	}

	@media screen and (max-height: 368px) {
		#news {
			display: none;
		}
	}

	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
		}

		#hero {
			display: block;
			padding-top: 10%;
		}

		#links {
			flex-wrap: wrap;
		}

		#links a.button {
			padding: 14px 18px;
		}

		#news {
			right: 16px;
			left: 16px;
			bottom: 2.5rem;
			max-width: 100%;
		}

		h1 {
			line-height: 1.5;
		}
	}

	.two-columns {
		display: grid;
		gap: 3rem;
		margin-bottom: 4rem;
	}

	/* Responsive (lg = 1024px) */
	@media (min-width: 1024px) {
		.two-columns {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	/* Headers */
	.section-header {
		margin-bottom: 2rem;
	}

	.title {
		font-size: 2.25rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		letter-spacing: 1px;
	}

	.title.teal {
		color: #4ecdc4;
	}
	.title.orange {
		color: #ff6b35;
	}

	.underline {
		height: 4px;
		width: 8rem;
		border-radius: 999px;
		background: linear-gradient(to right, var(--color-start), #fdc830);
	}

	.underline.teal {
		--color-start: #4ecdc4;
	}

	.underline.orange {
		--color-start: #ff6b35;
	}

	/* Projects */
	.projects {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	@keyframes float {
		0% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-8px);
		}
		100% {
			transform: translateY(0);
		}
	}

	.experience-section {
		margin-bottom: 4rem;
		opacity: 0;
		transform: translateY(50px);
		animation: fadeUp 0.8s ease forwards;
		animation-delay: 0.6s;
	}

	/* Header */
	.experience-header {
		margin-bottom: 3rem;
		text-align: center;
	}

	.experience-header h2 {
		font-size: 2.25rem; /* text-4xl */
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: #ff6b35;
		letter-spacing: 1px;
	}

	.experience-underline {
		height: 4px;
		width: 8rem;
		margin: 0 auto;
		border-radius: 999px;
		background: linear-gradient(to right, #ff6b35, #fdc830);
	}

	/* Animación */
	@keyframes fadeUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.about-section {
		margin-top: 6rem;
		animation: fadeUp 0.8s ease forwards;
		opacity: 0;
	}

	.title-wrapper {
		margin-bottom: 2rem;
	}

	.title-wrapper h2 {
		font-size: 2.5rem;
		font-weight: bold;
		color: #fdc830;
	}

	.title-line {
		height: 4px;
		width: 120px;
		background: linear-gradient(to right, #fdc830, #ff6b35);
		border-radius: 999px;
		margin-top: 0.5rem;
	}

	.about-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 768px) {
		.about-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.about-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.about-card {
		background: linear-gradient(to bottom right, #1a1f3a, #0a0e27);
		padding: 1.5rem;
		border: 2px solid;
		border-radius: 4px;
		transition: all 0.3s ease;
		box-shadow: 0 0 20px rgba(78, 205, 196, 0.2);
	}

	.about-card:hover {
		transform: translateY(-5px) scale(1.05);
		box-shadow: 0 0 30px rgba(78, 205, 196, 0.5);
	}

	.icon-wrapper {
		width: 48px;
		height: 48px;
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		animation: floatIcon 5s infinite ease-in-out;
	}

	.about-card p {
		color: #a8b2d1;
		line-height: 1.6;
	}

	/* Footer */
	.retro-footer {
		border-top: 2px solid #ff6b35;
		background: linear-gradient(to right, #0a0e27, #1a1f3a);
		margin-top: 5rem;
	}

	.footer-container {
		max-width: 1200px;
		margin: auto;
		padding: 2rem;
		text-align: center;
	}

	.retro-code {
		color: #4ecdc4;
		font-family: monospace;
	}

	.retro-code span {
		color: #ff6b35;
	}

	.copyright {
		color: #a8b2d1;
		font-size: 0.9rem;
		margin-top: 0.5rem;
	}

	/* Animations */
	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(50px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes floatIcon {
		0% {
			transform: rotate(0deg);
		}
		25% {
			transform: rotate(10deg);
		}
		50% {
			transform: rotate(-10deg);
		}
		75% {
			transform: rotate(5deg);
		}
		100% {
			transform: rotate(0deg);
		}
	}
</style>
